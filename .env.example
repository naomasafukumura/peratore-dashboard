# コピーして .env.local にリネームし、値を埋める（.env.local は Git に含めない）
# Neon ダッシュボードの接続文字列
DATABASE_URL=

# OpenAI（教材まわりの API で使用）
OPENAI_API_KEY=

# ElevenLabs（音声生成）
ELEVENLABS_API_KEY=

# Google OAuth（受講生ログイン）— コンソールの承認リダイレクト URI に
#   http://localhost:3000/api/auth/callback/google
#   （本番ドメインの /api/auth/callback/google）を追加
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# NextAuth / Auth.js 用（例: openssl rand -base64 32）。v4 互換で NEXTAUTH_SECRET でも可（どちらか1つでよい）
AUTH_SECRET=
# NEXTAUTH_SECRET=
# 本番では https://your-domain.com（任意・未設定時はリクエストから推論）
# AUTH_URL=

# 先生用（設定すると / と /teacher/* でパスワード必須・教材の書き換え系 API も要ログイン）
TEACHER_PASSWORD=
# 任意: JWT 署名専用シークレット（未設定時は TEACHER_PASSWORD を使う）
# TEACHER_AUTH_SECRET=
