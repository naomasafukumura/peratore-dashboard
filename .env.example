# コピーして .env.local にリネームし、値を埋める（.env.local は Git に含めない）
# Neon ダッシュボードの接続文字列
DATABASE_URL=

# OpenAI（教材まわりの API で使用）
OPENAI_API_KEY=

# ElevenLabs（音声生成）
ELEVENLABS_API_KEY=

# Google OAuth（受講生ログイン）— コンソールの承認リダイレクト URI に
#   http://localhost:3000/api/auth/callback/google
#   （本番ドメインの /api/auth/callback/google）を追加
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# NextAuth / Auth.js 用（例: openssl rand -base64 32）。v4 互換で NEXTAUTH_SECRET でも可（どちらか1つでよい）
AUTH_SECRET=
# NEXTAUTH_SECRET=
# 本番では https://your-domain.com（任意・未設定時はリクエストから推論）
# AUTH_URL=

# 先生用（設定すると / と /teacher/* でパスワード必須・教材の書き換え系 API も要ログイン）
# ローカル: .env.local に書き next dev を再起動。Vercel: Project → Settings → Environment Variables に
# TEACHER_PASSWORD を追加し、Production と Preview の両方にチェック → Redeploy。
TEACHER_PASSWORD=test1234
# 任意: JWT 署名専用シークレット（未設定時は TEACHER_PASSWORD を使う）
# TEACHER_AUTH_SECRET=

# --- Vercel デプロイ失敗監視 cron（/api/cron/error-monitor）---
# Cron リクエストを認証するシークレット（例: openssl rand -base64 32）
CRON_SECRET=
# Vercel ダッシュボード → Settings → Tokens で発行（read-only 権限で可）
VERCEL_API_TOKEN=
# Vercel ダッシュボード → プロジェクトの Settings → General → Project ID
VERCEL_PROJECT_ID=
# Vercel ダッシュボード → Team Settings → General → Team ID（Pro/Team プラン）
VERCEL_TEAM_ID=
# 要約は既存の OPENAI_API_KEY（上記）を再利用（gpt-4o-mini）。追加キー不要
# Slack アプリの Incoming Webhook URL（小文字キー・既存キーと統一）
slack_webhook=
